{
  "name": "cabinrentals-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "check-tokens": "node scripts/check-design-tokens.js",
    "prebuild": "node scripts/check-design-tokens.js",
    "deploy-check": "npm run lint && npm run build",
    "test": "npx playwright test",
    "test:health": "npx playwright test tests/health.spec.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-build-classic": "^41.4.2",
    "@ckeditor/ckeditor5-react": "^6.3.0",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.38.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^2.30.0",
    "lucide-react": "^1.7.0",
    "next": "^14.0.4",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.22.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3"
  }
}
